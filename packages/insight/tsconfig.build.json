{
  "extends": "../../tsconfig.app.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": false,
    "rootDir": "../../src/bi",
    "outDir": "./dist/types",
    "tsBuildInfoFile": "./dist/types/.tsbuildinfo",
    "baseUrl": "../..",
    "paths": {
      "@ultigrid/core": ["./packages/core/dist/types/index.d.ts"]
    }
  },
  "include": ["../../src/bi/**/*.ts", "../../src/bi/**/*.tsx"]
}
